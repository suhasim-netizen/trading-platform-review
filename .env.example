# TradeStation API Credentials
TS_CLIENT_ID=your_client_id_here
TS_CLIENT_SECRET=your_client_secret_here
TS_REDIRECT_URI=http://localhost:8080

# Account IDs
TS_EQUITY_ACCOUNT_ID=your_equity_account_id
TS_OPTIONS_ACCOUNT_ID=your_equity_account_id
TS_FUTURES_ACCOUNT_ID=your_futures_account_id
TS_ACCOUNT_ID=your_futures_account_id

# Encryption
SECRET_KEY=generate_with_python_secrets_module
TOKEN_ENCRYPTION_KEY=generate_with_fernet_keygen

# Broker URLs (paper trading)
PAPER_TRADING_MODE=true
BROKER_API_BASE_URL=https://sim.api.tradestation.com
BROKER_WS_BASE_URL=wss://sim.api.tradestation.com
MARKET_DATA_BASE_URL=https://api.tradestation.com

# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/trading_platform
